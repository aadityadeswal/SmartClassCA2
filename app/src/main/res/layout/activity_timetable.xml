<?xml version="1.0" encoding="utf-8"?>

<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F6F8FC">

    <!-- HEADER -->

    <LinearLayout
        android:id="@+id/headerLayout"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="26dp"
        android:background="#3F51B5"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:text="AI Timetable Generator"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="@android:color/white"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <TextView
            android:text="Automatically create a smart weekly schedule"
            android:textSize="14sp"
            android:textColor="#E8EAF6"
            android:layout_marginTop="4dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

    </LinearLayout>

    <!-- SCROLL AREA -->

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/headerLayout"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- INPUT CARD -->

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="26dp"
                app:cardElevation="10dp"
                app:cardBackgroundColor="@android:color/white"
                android:layout_marginBottom="18dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="22dp">

                    <TextView
                        android:text="Add Subjects"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="#111"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>

                    <EditText
                        android:id="@+id/etSubject"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:layout_marginTop="16dp"
                        android:hint="Subject Name"
                        android:padding="14dp"
                        android:background="@drawable/bg_input"/>

                    <EditText
                        android:id="@+id/etTeacher"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:layout_marginTop="12dp"
                        android:hint="Teacher Name"
                        android:padding="14dp"
                        android:background="@drawable/bg_input"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnAdd"
                        android:layout_width="match_parent"
                        android:layout_height="54dp"
                        android:text="Add Subject"
                        android:textAllCaps="false"
                        android:textStyle="bold"
                        android:textSize="15sp"
                        android:layout_marginTop="18dp"
                        android:backgroundTint="#4CAF50"
                        android:textColor="@android:color/white"
                        app:cornerRadius="22dp"/>

                    <!-- AI ANIMATION TEXT (ONLY NEW THING ADDED) -->

                    <TextView
                        android:id="@+id/tvLoadingAI"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Analyzing Subjects..."
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="#3F51B5"
                        android:gravity="center"
                        android:layout_marginTop="10dp"
                        android:visibility="gone"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnGenerateAI"
                        android:layout_width="match_parent"
                        android:layout_height="54dp"
                        android:text="Generate AI Timetable"
                        android:textAllCaps="false"
                        android:textStyle="bold"
                        android:textSize="15sp"
                        android:layout_marginTop="10dp"
                        android:backgroundTint="#3F51B5"
                        android:textColor="@android:color/white"
                        app:cornerRadius="22dp"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnResetTimetable"
                        android:layout_width="match_parent"
                        android:layout_height="54dp"
                        android:text="Create New Timetable"
                        android:textAllCaps="false"
                        android:textStyle="bold"
                        android:textSize="15sp"
                        android:layout_marginTop="10dp"
                        android:backgroundTint="#E5E7EB"
                        android:textColor="#111111"
                        app:cornerRadius="22dp"/>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- SUBJECT GRID (NOT REMOVED) -->

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="26dp"
                app:cardElevation="10dp"
                app:cardBackgroundColor="@android:color/white"
                android:layout_marginBottom="18dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="22dp">

                    <TextView
                        android:text="Added Subjects"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="#111"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>

                    <TextView
                        android:text="Subjects you added will appear here"
                        android:textSize="13sp"
                        android:textColor="#777"
                        android:layout_marginTop="4dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvSubjects"
                        android:layout_width="match_parent"
                        android:layout_height="200dp"
                        android:layout_marginTop="14dp"/>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>