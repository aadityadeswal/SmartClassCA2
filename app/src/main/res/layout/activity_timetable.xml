<?xml version="1.0" encoding="utf-8"?>

<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#E8F0FF">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Smart AI Timetable"
                android:textSize="26sp"
                android:textStyle="bold"
                android:textColor="#1A237E"
                android:layout_marginBottom="20dp"/>

            <!-- Input Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="20dp"
                app:cardElevation="8dp"
                android:layout_marginBottom="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <EditText
                        android:id="@+id/etSubject"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Subject"
                        android:padding="12dp"/>

                    <EditText
                        android:id="@+id/etTeacher"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Teacher"
                        android:layout_marginTop="10dp"
                        android:padding="12dp"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnAdd"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Add Subject"
                        android:textAllCaps="false"
                        android:layout_marginTop="15dp"
                        android:backgroundTint="#4CAF50"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnGenerateAI"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Generate AI Timetable"
                        android:textAllCaps="false"
                        android:layout_marginTop="10dp"
                        android:backgroundTint="#3F51B5"/>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Timetable Grid -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardSchedule"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:visibility="gone"
                app:cardCornerRadius="20dp"
                app:cardElevation="10dp">

                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <TableLayout
                        android:id="@+id/tableTimetable"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:padding="16dp"
                        android:stretchColumns="*"/>

                </HorizontalScrollView>

            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

    </ScrollView>

</LinearLayout>